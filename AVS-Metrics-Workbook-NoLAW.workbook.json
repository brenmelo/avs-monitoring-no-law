    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": { "json": "## Storage\r\nvSAN datastore utilization from the platform metrics API plus external datastore inventory from Resource Graph. No LAW required." }
          },
          {
            "type": 10,
            "content": {
              "chartId": "stg-used-pct",
              "version": "MetricsItem/2.0",
              "size": 0,
              "chartType": 2,
              "resourceType": "Microsoft.AVS/privateClouds",
              "metricScope": 0,
              "resourceParameter": "AVSInstance",
              "resourceIds": [ "{AVSInstance}" ],
              "timeContextFromParameter": "TimeRange",
              "timeContext": { "durationMs": 172800000 },
              "metrics": [
                {
                  "namespace": "microsoft.avs/privateclouds",
                  "metric": "microsoft.avs/privateclouds--DiskUsedPercentage",
                  "aggregation": 4,
                  "splitBy": [ "dsname" ]
                }
              ],
              "title": "Datastore Used (%) by Datastore",
              "showRefreshButton": true
            },
            "customWidth": "50",
            "name": "stg-used-pct"
          },
          {
            "type": 10,
            "content": {
              "chartId": "stg-used-gb",
              "version": "MetricsItem/2.0",
              "size": 0,
              "chartType": 2,
              "resourceType": "Microsoft.AVS/privateClouds",
              "metricScope": 0,
              "resourceParameter": "AVSInstance",
              "resourceIds": [ "{AVSInstance}" ],
              "timeContextFromParameter": "TimeRange",
              "timeContext": { "durationMs": 172800000 },
              "metrics": [
                {
                  "namespace": "microsoft.avs/privateclouds",
                  "metric": "microsoft.avs/privateclouds--DiskUsedLatest",
                  "aggregation": 4,
                  "splitBy": [ "dsname" ]
                }
              ],
              "title": "Datastore Disk Used (GB) by Datastore",
              "showRefreshButton": true
            },
            "customWidth": "50",
            "name": "stg-used-gb"
          },
          {
            "type": 10,
            "content": {
              "chartId": "stg-capacity",
              "version": "MetricsItem/2.0",
              "size": 0,
              "chartType": 2,
              "resourceType": "Microsoft.AVS/privateClouds",
              "metricScope": 0,
              "resourceParameter": "AVSInstance",
              "resourceIds": [ "{AVSInstance}" ],
              "timeContextFromParameter": "TimeRange",
              "timeContext": { "durationMs": 172800000 },
              "metrics": [
                {
                  "namespace": "microsoft.avs/privateclouds",
                  "metric": "microsoft.avs/privateclouds--DiskCapacityLatest",
                  "aggregation": 3,
                  "splitBy": [ "dsname" ]
                }
              ],
              "title": "Datastore Capacity (GB) by Datastore",
              "showRefreshButton": true
            },
            "name": "stg-capacity"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\r\n| where type == 'microsoft.avs/privateclouds/clusters/datastores'\r\n| extend pcName = tostring(split(id, '/')[8])\r\n| extend clusterName = tostring(split(id, '/')[10])\r\n| extend netAppVolume = tostring(properties.netAppVolume.id)\r\n| extend elasticSanVolume = tostring(properties.elasticSanVolume.targetIqn)\r\n| extend datastoreType = case(isnotempty(netAppVolume), 'ANF', isnotempty(elasticSanVolume), 'Elastic SAN', 'Pure Storage')\r\n| extend status = tostring(properties.status)\r\n| extend provisioningState = tostring(properties.provisioningState)\r\n| project name, pcName, clusterName, datastoreType, status, provisioningState, resourceGroup",
              "size": 0,
              "title": "External Datastores (ANF / Elastic SAN / Pure)",
              "noDataMessage": "No external datastores attached",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [ "{Subscription}" ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "datastoreType",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        { "operator": "==", "thresholdValue": "ANF", "representation": "blue", "text": "{0}{1}" },
                        { "operator": "==", "thresholdValue": "Elastic SAN", "representation": "purple", "text": "{0}{1}" },
                        { "operator": "==", "thresholdValue": "Pure Storage", "representation": "orange", "text": "{0}{1}" },
                        { "operator": "Default", "thresholdValue": null, "representation": "gray", "text": "{0}{1}" }
                      ]
                    }
                  },
                  {
                    "columnMatch": "status",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        { "operator": "==", "thresholdValue": "Accessible", "representation": "success", "text": "{0}{1}" },
                        { "operator": "==", "thresholdValue": "Attached", "representation": "success", "text": "{0}{1}" },
                        { "operator": "Default", "thresholdValue": null, "representation": "warning", "text": "{0}{1}" }
                      ]
                    }
                  }
                ],
                "filter": true
              }
            },
            "name": "stg-external"
          }
        ]
      },
      "conditionalVisibility": { "parameterName": "Tab", "comparison": "isEqualTo", "value": "Storage" },
      "name": "group-storage"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": { "json": "## Capacity & Inventory\r\nSKU breakdown, host counts, and estimated vSAN raw capacity per private cloud. All from Azure Resource Graph (free)." }
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\r\n| where type == 'microsoft.avs/privateclouds' or type == 'microsoft.avs/privateclouds/clusters'\r\n| extend pcName = iff(type == 'microsoft.avs/privateclouds', name, tostring(split(id, '/')[8]))\r\n| extend clusterName = iff(type == 'microsoft.avs/privateclouds', 'Management', name)\r\n| extend clusterSize = iff(type == 'microsoft.avs/privateclouds', toint(properties.managementCluster.clusterSize), toint(properties.clusterSize))\r\n| extend skuName = tostring(sku.name)\r\n| project pcName, clusterName, clusterSize, skuName, location, resourceGroup",
              "size": 0,
              "title": "Cluster Inventory",
              "noDataMessage": "No clusters found",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [ "{Subscription}" ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  { "columnMatch": "clusterSize", "formatter": 4, "formatOptions": { "palette": "blue", "min": 3, "max": 16 } },
                  {
                    "columnMatch": "skuName",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        { "operator": "contains", "thresholdValue": "AV36P", "representation": "purple", "text": "{0}{1}" },
                        { "operator": "contains", "thresholdValue": "AV36", "representation": "blue", "text": "{0}{1}" },
                        { "operator": "contains", "thresholdValue": "AV52", "representation": "green", "text": "{0}{1}" },
                        { "operator": "contains", "thresholdValue": "AV64", "representation": "orange", "text": "{0}{1}" },
                        { "operator": "Default", "thresholdValue": null, "representation": "gray", "text": "{0}{1}" }
                      ]
                    }
                  }
                ],
                "filter": true,
                "labelSettings": [
                  { "columnId": "pcName", "label": "Private Cloud" },
                  { "columnId": "clusterName", "label": "Cluster" },
                  { "columnId": "clusterSize", "label": "Hosts" },
                  { "columnId": "skuName", "label": "SKU" }
                ]
              }
            },
            "name": "cap-clusters"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\r\n| where type == 'microsoft.avs/privateclouds'\r\n| where id in ({AVSInstance})\r\n| extend skuName = tostring(sku.name)\r\n| extend hostCount = toint(properties.managementCluster.clusterSize)\r\n| summarize Hosts = sum(hostCount), Clouds = count() by skuName\r\n| order by Hosts desc",
              "size": 0,
              "title": "SKU Distribution",
              "noDataMessage": "No private clouds found",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [ "{Subscription}" ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "cap-sku-dist"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\r\n| where type == 'microsoft.avs/privateclouds'\r\n| where id in ({AVSInstance})\r\n| extend hostCount = toint(properties.managementCluster.clusterSize)\r\n| summarize Hosts = sum(hostCount) by location\r\n| order by Hosts desc",
              "size": 0,
              "title": "Hosts by Region",
              "noDataMessage": "No private clouds found",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [ "{Subscription}" ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "cap-region-dist"
          }
        ]
      },
      "conditionalVisibility": { "parameterName": "Tab", "comparison": "isEqualTo", "value": "Capacity" },
      "name": "group-capacity"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": { "json": "## Alerts\r\nActive and recent alerts on AVS resources. Sourced from Azure Alerts Management (free, no LAW required)." }
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "alertsmanagementresources\r\n| where type =~ 'microsoft.alertsmanagement/alerts'\r\n| where (id contains 'microsoft.avs/privatecloud') or properties.essentials.targetResourceType =~ 'microsoft.avs/privateclouds'\r\n| extend Severity = tostring(properties.essentials.severity)\r\n| summarize Count = count() by Severity\r\n| extend Label = case(Severity == 'Sev0', 'Critical', Severity == 'Sev1', 'Error', Severity == 'Sev2', 'Warning', Severity == 'Sev3', 'Informational', Severity == 'Sev4', 'Verbose', Severity)\r\n| extend SortOrder = case(Severity == 'Sev0', 0, Severity == 'Sev1', 1, Severity == 'Sev2', 2, Severity == 'Sev3', 3, 4)\r\n| sort by SortOrder asc\r\n| project Label, Count",
              "size": 4,
              "title": "Alerts by Severity",
              "noDataMessage": "No alerts - environment is healthy",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [ "{Subscription}" ],
              "visualization": "tiles",
              "tileSettings": {
                "showBorder": true,
                "titleContent": {
                  "columnMatch": "Label",
                  "formatter": 18,
                  "formatOptions": {
                    "thresholdsOptions": "icons",
                    "thresholdsGrid": [
                      { "operator": "==", "thresholdValue": "Critical", "representation": "Sev0", "text": "{0}{1}" },
                      { "operator": "==", "thresholdValue": "Error", "representation": "Sev1", "text": "{0}{1}" },
                      { "operator": "==", "thresholdValue": "Warning", "representation": "Sev2", "text": "{0}{1}" },
                      { "operator": "==", "thresholdValue": "Informational", "representation": "Sev3", "text": "{0}{1}" },
                      { "operator": "Default", "thresholdValue": null, "representation": "unknown", "text": "{0}{1}" }
                    ]
                  }
                },
                "leftContent": { "columnMatch": "Count", "formatter": 12, "formatOptions": { "palette": "none" } }
              }
            },
            "name": "alert-sev-summary"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "alertsmanagementresources\r\n| where type =~ 'microsoft.alertsmanagement/alerts'\r\n| where (id contains 'microsoft.avs/privatecloud') or properties.essentials.targetResourceType =~ 'microsoft.avs/privateclouds'\r\n| extend FireTime = todatetime(properties.essentials.startDateTime)\r\n| extend Severity = tostring(properties.essentials.severity)\r\n| extend AlertName = tostring(properties.essentials.alertRule)\r\n| extend AlertState = tostring(properties.essentials.alertState)\r\n| extend MonitorCondition = tostring(properties.essentials.monitorCondition)\r\n| extend TargetResource = tostring(properties.essentials.targetResourceName)\r\n| where FireTime {TimeRange}\r\n| project FireTime, Severity, AlertName, TargetResource, AlertState, MonitorCondition\r\n| order by FireTime desc",
              "size": 0,
              "title": "Alerts in Selected Time Range",
              "noDataMessage": "No alerts in the selected time range",
              "timeContextFromParameter": "TimeRange",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [ "{Subscription}" ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Severity",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        { "operator": "==", "thresholdValue": "Sev0", "representation": "4", "text": "Critical" },
                        { "operator": "==", "thresholdValue": "Sev1", "representation": "3", "text": "Error" },
                        { "operator": "==", "thresholdValue": "Sev2", "representation": "2", "text": "Warning" },
                        { "operator": "==", "thresholdValue": "Sev3", "representation": "1", "text": "Info" },
                        { "operator": "Default", "thresholdValue": null, "representation": "unknown", "text": "{0}{1}" }
                      ]
                    }
                  },
                  { "columnMatch": "FireTime", "formatter": 6 },
                  {
                    "columnMatch": "MonitorCondition",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        { "operator": "==", "thresholdValue": "Fired", "representation": "2", "text": "{0}{1}" },
                        { "operator": "==", "thresholdValue": "Resolved", "representation": "success", "text": "{0}{1}" },
                        { "operator": "Default", "thresholdValue": null, "representation": "info", "text": "{0}{1}" }
                      ]
                    }
                  }
                ],
                "filter": true
              }
            },
            "name": "alert-table"
          },
          {
            "type": 1,
            "content": {
              "json": "### Recommended next steps\r\nDeploy AVS metric and service health alert rules from the Enterprise Scale for AVS repo. These create alert rules directly on platform metrics (no LAW needed):\r\n\r\n- [Deploy Metric Alerts](https://portal.azure.com/#create/Microsoft.Template/uri/https%3A%2F%2Fraw.githubusercontent.com%2FAzure%2FEnterprise-Scale-for-AVS%2Fmain%2FBrownField%2FMonitoring%2FAVS-Utilization-Alerts%2FARM%2FAVSMonitor.deploy.json)\r\n- [Deploy Service Health Alerts](https://portal.azure.com/#create/Microsoft.Template/uri/https%3A%2F%2Fraw.githubusercontent.com%2FAzure%2FEnterprise-Scale-for-AVS%2Fmain%2FBrownField%2FMonitoring%2FAVS-Service-Health%2FARM%2FAVSServiceHealth.deploy.json)"
            },
            "name": "alert-help"
          }
        ]
      },
      "conditionalVisibility": { "parameterName": "Tab", "comparison": "isEqualTo", "value": "Alerts" },
      "name": "group-alerts"
    }
  ],
  "fallbackResourceIds": [ "Azure Monitor" ],
  "$schema": "https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json"
}
